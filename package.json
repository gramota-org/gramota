{
  "name": "eudi-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source TypeScript SDK for the EU Digital Identity Wallet.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r build && vitest run",
    "test:watch": "vitest",
    "test:coverage": "pnpm -r build && vitest run --coverage",
    "test:live": "pnpm -r build && EUDI_LIVE=1 vitest run packages/e2e/tests/interop/",
    "test:all": "pnpm -r build && EUDI_LIVE=1 vitest run",
    "typecheck": "pnpm -r build && pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist coverage *.tsbuildinfo",
    "demo": "pnpm --filter @gramota/demo build && node packages/demo/dist/index.js",
    "demo:self-loop": "pnpm --filter @gramota/demo build && node packages/demo/dist/index.js self-loop",
    "demo:eu-pid": "pnpm --filter @gramota/demo build && node packages/demo/dist/index.js eu-pid",
    "demo:list": "pnpm --filter @gramota/demo build && node packages/demo/dist/index.js list"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
