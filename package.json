{
  "name": "eudi-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source TypeScript SDK for the EU Digital Identity Wallet.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist coverage *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
