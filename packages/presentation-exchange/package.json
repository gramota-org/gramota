{
  "name": "@gramota/presentation-exchange",
  "version": "0.1.4",
  "description": "DIF Presentation Exchange v2 — match credentials against a verifier's presentation_definition.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gramota/core": "workspace:*",
    "@gramota/sd-jwt": "workspace:*"
  },
  "author": "Petromil Pavlov <petromilpavlov@gmail.com>",
  "homepage": "https://github.com/gramota-org/gramota#readme",
  "bugs": {
    "url": "https://github.com/gramota-org/gramota/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "presentation-exchange",
    "dif",
    "pe",
    "pe-v2",
    "oid4vp",
    "eudi",
    "verifiable-credentials"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gramota-org/gramota.git",
    "directory": "packages/presentation-exchange"
  }
}
