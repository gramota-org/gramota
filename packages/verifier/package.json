{
  "name": "@gramota/verifier",
  "version": "0.0.0",
  "description": "Relying-party verifier for the EU Digital Identity Wallet. One client, one method, full IETF SD-JWT-VC + KB-JWT spec compliance.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gramota/jose": "workspace:*",
    "@gramota/oid4vp": "workspace:*",
    "@gramota/sd-jwt": "workspace:*",
    "@gramota/status-list": "workspace:*",
    "@gramota/trust": "workspace:*"
  },
  "devDependencies": {
    "@gramota/issuer": "workspace:*",
    "jose": "^5.9.6"
  }
}
